# ─── @regista11/web env (P17) ──────────────────────────────────────────────
# Copy to .env.local for development; Vercel sets these via project settings.
# .env / .env.local are gitignored — never commit real values.

# WalletConnect cloud project id. Get one at https://cloud.walletconnect.com.
# Without this, the wallet modal still renders but cannot open a connection.
NEXT_PUBLIC_WC_PROJECT_ID="get-from-cloud.walletconnect.com"

# X Layer relayer wallet for /api/facilitator/stake. Funded with OKB for gas.
# Server-only — must NEVER appear in any client bundle. Verify after build:
#   grep -r "RELAYER_PRIVATE_KEY" packages/web/.next/static  → no matches
RELAYER_PRIVATE_KEY="0xreplace-with-64-hex-chars-do-not-commit"

# NEXT_PUBLIC_FACILITATOR_URL is intentionally NOT used — the API route at
# /api/facilitator/stake lives inside this Next.js app and is the facilitator.

# ─── @regista11/web env (P19 — Farcaster frames) ──────────────────────────
# Absolute URL Farcaster clients use to construct frame target + image URLs.
# Must match the deploy origin exactly (no trailing slash). In dev, the
# Warpcast frame validator needs a public tunnel (ngrok / cloudflared) →
# point this at the tunnel URL while testing.
NEXT_PUBLIC_APP_URL="https://regista11.xyz"
